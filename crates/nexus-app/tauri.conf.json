{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus",
  "version": "0.1.0",
  "identifier": "dev.nexus.ide",
  "build": {
    "beforeDevCommand": "npm --prefix ../app run dev",
    "beforeBuildCommand": "npm --prefix ../app run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Nexus",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'"],
        "script-src": ["'self'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "connect-src": ["'self'", "ipc:", "http://ipc.localhost", "https:"],
        "img-src": ["'self'", "data:", "blob:", "https:", "asset:", "http://asset.localhost"],
        "font-src": ["'self'", "data:", "https:"],
        "frame-src": ["'self'", "blob:", "https:", "tauri:"],
        "object-src": ["'none'"],
        "base-uri": ["'self'"],
        "form-action": ["'self'"]
      },
      "devCsp": {
        "default-src": ["'self'"],
        "script-src": ["'self'", "'unsafe-eval'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "connect-src": ["'self'", "ipc:", "http://ipc.localhost", "https:", "ws:", "wss:", "http://localhost:5173"],
        "img-src": ["'self'", "data:", "blob:", "https:", "asset:", "http://asset.localhost"],
        "font-src": ["'self'", "data:", "https:"],
        "frame-src": ["'self'", "blob:", "https:", "http:", "tauri:"],
        "object-src": ["'none'"],
        "base-uri": ["'self'"],
        "form-action": ["'self'"]
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
