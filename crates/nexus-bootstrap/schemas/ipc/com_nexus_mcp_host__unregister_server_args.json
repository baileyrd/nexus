{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "McpUnregisterServerArgs",
  "description": "Args for `unregister_server` (handler `12`).",
  "type": "object",
  "properties": {
    "name": {
      "description": "Server `name` to remove.",
      "type": "string"
    },
    "plugin_id": {
      "description": "Reverse-DNS id of the plugin claiming to own the entry.",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": [
    "name",
    "plugin_id"
  ]
}
