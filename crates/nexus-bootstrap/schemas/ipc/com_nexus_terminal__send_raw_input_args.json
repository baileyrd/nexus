{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SendRawInputArgs",
  "description": "Arguments for `send_raw_input`.",
  "type": "object",
  "properties": {
    "data": {
      "description": "Raw bytes to write (no newline appended).",
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "maximum": 255,
        "minimum": 0
      }
    },
    "id": {
      "description": "Target session id.",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": [
    "id",
    "data"
  ]
}
