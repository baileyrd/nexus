{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CreateSessionArgs",
  "description": "Arguments for `create_session`.",
  "type": "object",
  "properties": {
    "env": {
      "description": "Env vars to merge on top of the inherited environment.",
      "type": "array",
      "default": [],
      "items": {
        "type": "array",
        "maxItems": 2,
        "minItems": 2,
        "prefixItems": [
          {
            "type": "string"
          },
          {
            "type": "string"
          }
        ]
      }
    },
    "name": {
      "description": "Human-readable label.",
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "shell": {
      "description": "Absolute path to the shell executable. `None` falls back to\nthe platform-default detection.",
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "shell_args": {
      "description": "Extra args to pass to the shell after the program name.",
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "working_dir": {
      "description": "Working directory.",
      "type": [
        "string",
        "null"
      ],
      "default": null
    }
  },
  "additionalProperties": false
}
