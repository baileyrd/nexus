{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ActivitySurface",
  "description": "Surface that originated the entry. Lossy on the wire — unknown\nvalues land in [`ActivitySurface::Other`] so a future emitter\n(community plugin) doesn't crash deserialisation. Producers that\ndon't fit any AI surface should use [`ActivitySurface::Other`] and\nrely on `origin` for typing.",
  "oneOf": [
    {
      "description": "Chat panel (`stream_chat`, mode=chat).",
      "type": "string",
      "const": "chat"
    },
    {
      "description": "RAG retrieve + chat (`stream_ask`).",
      "type": "string",
      "const": "ask"
    },
    {
      "description": "Cmd+I command-anywhere overlay (BL-032).",
      "type": "string",
      "const": "cmdi"
    },
    {
      "description": "Inline ghost completion (BL-034, mode=complete).",
      "type": "string",
      "const": "ghost"
    },
    {
      "description": "Headless single-shot completion (`complete` CLI / mode=complete).",
      "type": "string",
      "const": "complete"
    },
    {
      "description": "Auto-enrichment on save (BL-045).",
      "type": "string",
      "const": "enrich"
    },
    {
      "description": "File-system event surface — write / delete / rename.",
      "type": "string",
      "const": "file"
    },
    {
      "description": "Process / terminal session lifecycle (BL-057).",
      "type": "string",
      "const": "process"
    },
    {
      "description": "Git command boundary — commit / push / pull / merge.",
      "type": "string",
      "const": "git"
    },
    {
      "description": "Workflow run boundary — start / end.",
      "type": "string",
      "const": "workflow"
    },
    {
      "description": "Capability grant / revoke (security audit).",
      "type": "string",
      "const": "capability"
    },
    {
      "description": "Catch-all when the surface tag is missing or unknown.",
      "type": "string",
      "const": "other"
    }
  ]
}
