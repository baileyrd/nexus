{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PoolStats",
  "description": "`pool_stats` reply shape — exposed so a shell observability panel\ncan render queue depth + utilisation without scraping logs.",
  "type": "object",
  "properties": {
    "max": {
      "description": "Configured max concurrent runs (currently equals `workers`).",
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "queued": {
      "description": "Total tasks currently in `Queued` status.",
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "running": {
      "description": "Total tasks currently in `Running` status.",
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "workers": {
      "description": "Number of worker threads in the dedicated tokio runtime.",
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "required": [
    "workers",
    "queued",
    "running",
    "max"
  ]
}
