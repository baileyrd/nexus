{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StorageSearchArgs",
  "description": "Args for `com.nexus.storage::search` (handler id `7`).",
  "type": "object",
  "properties": {
    "limit": {
      "description": "Maximum number of results to return. Omit for the default of 50.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0
    },
    "mtime_after": {
      "title": "375 — only include blocks whose file mtime is on or after this",
      "description": "Unix-seconds timestamp.",
      "type": [
        "integer",
        "null"
      ],
      "format": "int64"
    },
    "mtime_before": {
      "title": "375 — only include blocks whose file mtime is on or before",
      "description": "this Unix-seconds timestamp.",
      "type": [
        "integer",
        "null"
      ],
      "format": "int64"
    },
    "offset": {
      "title": "375 — skip this many ranked hits before taking the page of",
      "description": "`limit`, for paging through results. Omit for no offset.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0
    },
    "query": {
      "description": "Full-text query string (Tantivy syntax).",
      "type": "string"
    },
    "sort": {
      "title": "375 — how to order hits. Omit for the default (BM25 relevance).",
      "anyOf": [
        {
          "$ref": "#/$defs/StorageSearchSort"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "query"
  ],
  "$defs": {
    "StorageSearchSort": {
      "title": "375 — sort order for `com.nexus.storage::search`. Mirror of",
      "description": "[`crate::search::SearchSort`].",
      "oneOf": [
        {
          "description": "BM25 relevance, descending score (the historical/only behavior).",
          "type": "string",
          "const": "relevance"
        },
        {
          "description": "Most-recently-modified block first.",
          "type": "string",
          "const": "mtime_desc"
        },
        {
          "description": "Least-recently-modified block first.",
          "type": "string",
          "const": "mtime_asc"
        }
      ]
    }
  }
}
