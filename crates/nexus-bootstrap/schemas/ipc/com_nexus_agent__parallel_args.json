{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ParallelArgs",
  "description": "Args for [`HANDLER_PARALLEL`].",
  "type": "object",
  "properties": {
    "jobs": {
      "description": "Jobs fanned out concurrently; results returned in input order.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/ParallelJob"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "jobs"
  ],
  "$defs": {
    "ParallelJob": {
      "description": "One job for [`HANDLER_PARALLEL`].",
      "type": "object",
      "properties": {
        "archetype": {
          "description": "Archetype short name.",
          "type": "string"
        },
        "goal": {
          "description": "Natural-language goal.",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "archetype",
        "goal"
      ]
    }
  }
}
