{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StorageVectorMatch",
  "description": "One match row in a `vector_query` reply. Mirror of\n[`crate::vectorstore::ChunkMatch`].",
  "type": "object",
  "properties": {
    "block_id": {
      "description": "Identifier of the originating block.",
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "chunk_text": {
      "description": "Textual content of the matched chunk.",
      "type": "string"
    },
    "file_path": {
      "description": "Path of the source file (forge-relative).",
      "type": "string"
    },
    "score": {
      "description": "Cosine similarity score. Higher is more relevant.",
      "type": "number",
      "format": "float"
    }
  },
  "additionalProperties": false,
  "required": [
    "file_path",
    "block_id",
    "chunk_text",
    "score"
  ]
}
