{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NoteNearDuplicatePair",
  "description": "One pair in [`NoteFindDuplicatesResult::near`].",
  "type": "object",
  "properties": {
    "a": {
      "description": "Lexicographically-smaller forge-relative path.",
      "type": "string"
    },
    "b": {
      "description": "Lexicographically-greater forge-relative path.",
      "type": "string"
    },
    "similarity": {
      "description": "Cosine similarity in `[0.0, 1.0]` between the two files' mean-\npooled embedding vectors.",
      "type": "number",
      "format": "float"
    }
  },
  "additionalProperties": false,
  "required": [
    "a",
    "b",
    "similarity"
  ]
}
