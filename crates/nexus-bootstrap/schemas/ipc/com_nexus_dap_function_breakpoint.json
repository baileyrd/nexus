{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DapFunctionBreakpoint",
  "description": "One function-breakpoint row.",
  "type": "object",
  "properties": {
    "condition": {
      "description": "Optional condition expression.",
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "description": "Function name to break on.",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": [
    "name"
  ]
}
