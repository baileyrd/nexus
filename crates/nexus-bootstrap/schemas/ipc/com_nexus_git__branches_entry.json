{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitBranch",
  "description": "One entry in the `branches` handler's response array. Mirrors\n[`crate::types::BranchInfo`].",
  "type": "object",
  "properties": {
    "is_head": {
      "description": "`true` if this is the currently checked-out branch.",
      "type": "boolean"
    },
    "name": {
      "description": "Branch name.",
      "type": "string"
    },
    "upstream": {
      "description": "Upstream tracking branch name (e.g. `\"origin/main\"`).",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "name",
    "is_head"
  ]
}
