{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StorageWriteFileResult",
  "description": "Return type for `com.nexus.storage::write_file`. Mirror of\n[`crate::FileMetadata`].",
  "type": "object",
  "properties": {
    "content_hash": {
      "description": "SHA-256 hex digest of the file content.",
      "type": "string"
    },
    "modified_at": {
      "description": "Unix timestamp of last modification.",
      "type": "integer",
      "format": "int64"
    },
    "path": {
      "description": "Vault-relative path.",
      "type": "string"
    },
    "size_bytes": {
      "description": "File size in bytes.",
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "required": [
    "path",
    "size_bytes",
    "modified_at",
    "content_hash"
  ]
}
