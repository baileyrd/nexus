{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PipelineStage",
  "description": "One stage in [`HANDLER_PIPELINE`].",
  "type": "object",
  "properties": {
    "archetype": {
      "description": "Archetype short name.",
      "type": "string"
    },
    "goal_template": {
      "description": "Goal template — `{{prev}}` is substituted with the previous\nstage's textual summary before planning.",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": [
    "archetype",
    "goal_template"
  ]
}
