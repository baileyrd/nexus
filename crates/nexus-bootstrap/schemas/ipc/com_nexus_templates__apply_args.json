{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ApplyTemplateArgs",
  "description": "Args for `com.nexus.templates::apply` (handler `4`).",
  "type": "object",
  "properties": {
    "args": {
      "description": "Parameter overrides.",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "name": {
      "description": "Template name to apply.",
      "type": "string"
    },
    "overwrite": {
      "description": "If `false` (default), refuse to overwrite an existing file. If\n`true`, overwrite freely.",
      "type": "boolean",
      "default": false
    },
    "target": {
      "description": "Override the template's `target_path` (forge-relative). Optional.",
      "type": [
        "string",
        "null"
      ],
      "default": null
    }
  },
  "additionalProperties": false,
  "required": [
    "name"
  ]
}
