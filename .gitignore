**/target
**/*.rs.bk
Cargo.lock
# ts-rs's impl-features write external-type mirrors into a per-crate
# `bindings/` directory. Audit P1-3 IPC bindings live under
# `packages/nexus-extension-api/src/generated/ipc/`; the leftover
# `bindings/` is build-only.
crates/*/bindings/
# cargo-sweep timestamp marker
sweep.timestamp
.DS_Store
*.swp
# LibreOffice lockfiles
.~lock.*#
.superpowers/
.claude/*
!.claude/hooks/
!.claude/settings.json
.claude/settings.local.json
**/SESSION_SUMMARIES.md
# Per-install plugin settings written by the Settings modal.
plugins/*/settings.json
# Node / pnpm — workspace-wide
node_modules/
shell/dist/
packages/*/dist/
